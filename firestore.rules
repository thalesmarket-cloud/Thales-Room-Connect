rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == "thales.market@gmail.com");
    }

    // --- ENTITY VALIDATIONS ---

    function isValidRoom(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             (!('capacity' in data) || data.capacity is int) &&
             (!('equipment' in data) || data.equipment is list);
    }

    function isValidEmployee(data) {
      return data.keys().hasAll(['firstName', 'lastName', 'email']) &&
             data.firstName is string && data.firstName.size() > 0 &&
             data.lastName is string && data.lastName.size() > 0 &&
             data.email is string && data.email.size() > 0;
    }

    function isValidReservation(data) {
      return data.keys().hasAll(['roomId', 'subject', 'startTime', 'endTime', 'organizerId', 'organizerName']) &&
             isValidId(data.roomId) &&
             data.subject is string && data.subject.size() > 0 && data.subject.size() <= 200 &&
             data.startTime is string && data.endTime is string &&
             data.startTime < data.endTime &&
             data.organizerName is string &&
             (!('participants' in data) || data.participants is list) &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    // --- COLLECTION RULES ---

    match /rooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidRoom(incoming());
      allow update, delete: if isAdmin();
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow create: if (isAdmin() || (isSignedIn() && incoming().userId == request.auth.uid)) && isValidEmployee(incoming());
      allow update: if isAdmin() && isValidEmployee(incoming());
      allow delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      allow read: if isSignedIn();

      allow create: if isVerified() &&
                    isValidReservation(incoming()) &&
                    incoming().organizerId == request.auth.uid &&
                    exists(/databases/$(database)/documents/rooms/$(incoming().roomId));

      allow update: if isVerified() &&
                    (isOwner(existing().organizerId) || isAdmin()) &&
                    isValidReservation(incoming()) &&
                    incoming().organizerId == existing().organizerId &&
                    incoming().roomId == existing().roomId &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['subject', 'startTime', 'endTime', 'participants', 'updatedAt']);

      allow delete: if isVerified() && (isOwner(existing().organizerId) || isAdmin());
    }
  }
}
